{
  "name": "knowledge-hub",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev":         "concurrently --kill-others-on-fail --names \"API,WEB\" --prefix-colors \"bgYellow.black,bgCyan.black\" \"node src/index.js\" \"npm run dev --prefix frontend\"",
    "build":       "npm run build --prefix frontend",
    "start":       "concurrently --kill-others-on-fail --names \"API,WEB\" --prefix-colors \"bgYellow.black,bgCyan.black\" \"node src/index.js\" \"npm run start --prefix frontend\"",
    "install:all": "npm install && npm install --prefix frontend"
  },
  "dependencies": {
    "bcryptjs":    "^2.4.3",
    "concurrently":"^8.2.2",
    "cors":        "^2.8.5",
    "dotenv":      "^16.4.5",
    "express":     "^4.19.2",
    "jsonwebtoken":"^9.0.2",
    "mongoose":    "^8.4.0"
  }
}
